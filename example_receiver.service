[Unit]
Description = Example receiver
Wants = network-online.target
After = local-fs.target network-online.target

[Service]
User = student
WorkingDirectory = /home/student/workspace/mpc-rbt-student
ExecStart = /home/student/workspace/mpc-rbt-student/run_receiver.sh
Restart = on-failure
RestartSec = 5
TimeoutStopSec = 5

[Install]
WantedBy = multi-user.target
